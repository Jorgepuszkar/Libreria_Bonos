    "print(f\"   Tasa anual: {tasa_5y*100:.2f}%\")\n",
    "print(f\"   Monto final (5 años): £{monto_final_5y:,.2f}\")\n",
    "print(f\"   Ganancia total: £{monto_final_5y - monto:,.2f}\")\n",
    "\n",
    "print(\"\\n   Opción B: Invertir £1,000 en bono de 10 años\")\n",
    "tasa_10y = yields_df[yields_df['plazo'] == '10Y']['yield'].values[0]\n",
    "monto_final_10y = monto * (1 + tasa_10y) ** 10\n",
    "print(f\"   Monto inicial: £{monto:,.2f}\")\n",
    "print(f\"   Tasa anual: {tasa_10y*100:.2f}%\")\n",
    "print(f\"   Monto final (10 años): £{monto_final_10y:,.2f}\")\n",
